# DriveFort AI runtime
DRIVEFORT_HOST=127.0.0.1
DRIVEFORT_PORT=5000
DRIVEFORT_DEBUG=0

# Use only for analytical/offline development. Live dashboard actions normally require CARLA.
DRIVEFORT_ALLOW_MOCK=0

# Set a stable secret in shared or deployed environments.
DRIVEFORT_COMMAND_SECRET=replace-with-a-long-random-secret

# Optional database override
DRIVEFORT_INCIDENT_DB=data/drivefort_incidents.db

# Optional CARLA executable used by legacy Windows helper code
CARLA_EXE_PATH=D:\\Downloads\\CarlaSimulator\\WindowsNoEditor\\CarlaUE4.exe

# HMAC secret used by the V3 OTA verification demonstration.
DRIVEFORT_OTA_SECRET=replace-with-a-different-long-random-secret

# Controlled demo only: permits the UI to request a demonstration OTA signature.
# Keep disabled in shared or production-like environments.
DRIVEFORT_OTA_DEMO_SIGNING=0
